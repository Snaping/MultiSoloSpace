<Window x:Class="HookMgr.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows API Hook Manager" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="目标进程: " VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>
            <ComboBox x:Name="ProcessComboBox" Width="250" Margin="0,0,10,0"/>
            <Button x:Name="RefreshProcessButton" Content="刷新进程列表" Width="100" Margin="0,0,10,0" Click="RefreshProcessButton_Click"/>
            <Button x:Name="StartHookButton" Content="开始钩取" Width="80" Margin="0,0,10,0" Background="#4CAF50" Foreground="White" Click="StartHookButton_Click"/>
            <Button x:Name="StopHookButton" Content="停止钩取" Width="80" Margin="0,0,10,0" Background="#F44336" Foreground="White" IsEnabled="False" Click="StopHookButton_Click"/>
            <Button x:Name="SimulateCallButton" Content="模拟API调用" Width="100" Background="#2196F3" Foreground="White" Click="SimulateCallButton_Click"/>
        </StackPanel>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Background="#E0E0E0" Padding="5">
                    <TextBlock Text="可用API列表" FontWeight="Bold"/>
                </Border>
                
                <DataGrid Grid.Row="1" x:Name="ApiDataGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                          SelectionMode="Single" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                          CanUserAddRows="False" Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="状态" Binding="{Binding IsEnabled}" Width="50"/>
                        <DataGridTextColumn Header="API名称" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
            
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Gray"/>
            
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#E0E0E0" Padding="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="捕获的API调用列表" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="2" x:Name="SearchTextBox" Width="200" Margin="0,0,10,0" 
                                     TextChanged="SearchTextBox_TextChanged"/>
                            <Button Grid.Column="2" Content="清除列表" Width="80" Click="ClearCallsList_Click" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                    
                    <DataGrid Grid.Row="1" x:Name="CallsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                              SelectionMode="Single" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              CanUserAddRows="False" Margin="5" SelectionChanged="CallsDataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="时间" Binding="{Binding Timestamp}" Width="140"/>
                            <DataGridTextColumn Header="API名称" Binding="{Binding ApiName}" Width="120"/>
                            <DataGridTextColumn Header="模块" Binding="{Binding ModuleName}" Width="80"/>
                            <DataGridTextColumn Header="参数" Binding="{Binding Parameters}" Width="*"/>
                            <DataGridTextColumn Header="原始返回值" Binding="{Binding OriginalReturnValue}" Width="80"/>
                            <DataGridTextColumn Header="修改后返回值" Binding="{Binding ModifiedReturnValue}" Width="80"/>
                            <DataGridTextColumn Header="状态" Binding="{Binding IsModified}" Width="50"/>
                            <DataGridTextColumn Header="重定向" Binding="{Binding IsRedirected}" Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
                
                <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1,0,0,0" Margin="0,10,0,0" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="选中的调用详情:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock x:Name="DetailApiNameTextBlock" Text="API名称: " Margin="0,0,0,2"/>
                            <TextBlock x:Name="DetailParametersTextBlock" Text="参数: " Margin="0,0,0,2" TextWrapping="Wrap"/>
                            <TextBlock x:Name="DetailOriginalReturnTextBlock" Text="原始返回值: " Margin="0,0,0,2"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="修改返回值:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox x:Name="ModifiedReturnValueTextBox" Margin="0,0,0,5"/>
                            <Button Content="应用修改" Background="#FF9800" Foreground="White" Click="ApplyModifyReturnValue_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        
        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" Margin="0,10,0,0" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusTextBlock" Text="状态: 未连接" VerticalAlignment="Center"/>
                <TextBlock x:Name="HookStatusTextBlock" Text=" | 钩取状态: 未开始" VerticalAlignment="Center" Margin="10,0"/>
                <TextBlock x:Name="CallCountTextBlock" Text=" | 捕获调用数: 0" VerticalAlignment="Center" Margin="10,0"/>
                <TextBlock x:Name="LogPathTextBlock" Text=" | 日志路径: " VerticalAlignment="Center" Margin="10,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
