﻿<Window x:Class="HookMgr.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HookMgr.UI"
        mc:Ignorable="d"
        Title="Windows API Hook Manager - 系统调用捕获工具" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="目标进程: " VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>
                
                <ComboBox Grid.Column="1" x:Name="ProcessComboBox" Width="300" HorizontalAlignment="Left" 
                          SelectionChanged="ProcessComboBox_SelectionChanged"/>
                
                <Button Grid.Column="2" x:Name="RefreshProcessButton" Content="刷新进程列表" 
                        Width="100" Margin="10,0" Click="RefreshProcessButton_Click"/>
                
                <Button Grid.Column="3" x:Name="StartHookButton" Content="开始钩取" 
                        Width="100" Margin="10,0" Click="StartHookButton_Click" Background="#4CAF50" Foreground="White"/>
                
                <Button Grid.Column="4" x:Name="StopHookButton" Content="停止钩取" 
                        Width="100" Margin="10,0" Click="StopHookButton_Click" IsEnabled="False" Background="#F44336" Foreground="White"/>
                
                <Button Grid.Column="5" x:Name="SimulateCallButton" Content="模拟API调用" 
                        Width="120" Margin="10,0" Click="SimulateCallButton_Click" Background="#2196F3" Foreground="White"/>
            </Grid>
        </Border>
        
        <!-- 中间主区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧面板：API列表和设置 -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- API列表标题 -->
                    <Border Grid.Row="0" Background="#E0E0E0" CornerRadius="5,5,0,0">
                        <TextBlock Text="可用API列表" FontWeight="Bold" Margin="10" VerticalAlignment="Center"/>
                    </Border>
                    
                    <!-- API列表 -->
                    <DataGrid Grid.Row="1" x:Name="ApiDataGrid" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="ApiDataGrid_SelectionChanged"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="状态" Binding="{Binding IsEnabled, Converter={StaticResource BoolToStatusConverter}}" Width="50"/>
                            <DataGridTextColumn Header="API名称" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <!-- API控制按钮 -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                        <Button x:Name="EnableApiButton" Content="启用" Width="60" Margin="0,0,5,0" Click="EnableApiButton_Click"/>
                        <Button x:Name="DisableApiButton" Content="禁用" Width="60" Margin="5,0" Click="DisableApiButton_Click"/>
                    </StackPanel>
                    
                    <!-- 过滤和重定向设置 -->
                    <Border Grid.Row="3" BorderBrush="Gray" BorderThickness="0,1,0,0" Margin="0,5,0,0">
                        <Grid Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- 过滤设置 -->
                            <GroupBox Grid.Row="0" Header="过滤设置" Margin="0,0,0,5">
                                <Grid Margin="5">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <StackPanel Grid.Row="0" Orientation="Vertical">
                                        <TextBlock Text="包含过滤 (仅显示以下API:" Margin="0,0,0,2"/>
                                        <TextBox x:Name="IncludeFilterTextBox" Height="60" TextWrapping="Wrap" 
                                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,5"/>
                                        <Button Content="应用包含过滤" Click="ApplyIncludeFilter_Click" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,10,0,0">
                                        <TextBlock Text="排除过滤 (不显示以下API:" Margin="0,0,0,2"/>
                                        <TextBox x:Name="ExcludeFilterTextBox" Height="60" TextWrapping="Wrap" 
                                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,5"/>
                                        <Button Content="应用排除过滤" Click="ApplyExcludeFilter_Click" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </GroupBox>
                            
                            <!-- 重定向设置 -->
                            <GroupBox Grid.Row="1" Header="重定向设置" Margin="0,5,0,0">
                                <Grid Margin="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="API名称:" Margin="0,0,0,2"/>
                                        <TextBox x:Name="RedirectApiNameTextBox" Margin="0,0,0,5"/>
                                        <TextBlock Text="目标函数:" Margin="0,5,0,2"/>
                                        <TextBox x:Name="RedirectTargetTextBox" Margin="0,0,0,5"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <Button Content="设置重定向" Click="SetRedirect_Click" Width="100" Margin="0,0,0,5"/>
                                        <Button Content="移除重定向" Click="RemoveRedirect_Click" Width="100" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </GroupBox>
                            
                            <!-- 清除过滤按钮 -->
                            <Button Grid.Row="2" Content="清除所有过滤和重定向" 
                                    Click="ClearAllFilters_Click" Margin="0,10,0,0" HorizontalAlignment="Stretch"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
            
            <!-- 分隔线 -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Gray"/>
            
            <!-- 右侧主面板：API调用列表和详细信息 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- API调用列表 -->
                <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="#E0E0E0" CornerRadius="5,5,0,0">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" Text="捕获的API调用列表" FontWeight="Bold" VerticalAlignment="Center"/>
                                
                                <TextBox Grid.Column="2" x:Name="SearchTextBox" Width="200" Margin="0,0,10,0" 
                                         TextChanged="SearchTextBox_TextChanged" VerticalContentAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="搜索: " VerticalAlignment="Center" Margin="0,0,210,0"/>
                                
                                <Button Grid.Column="3" Content="清除列表" Click="ClearCallsList_Click" Width="80"/>
                            </Grid>
                        </Border>
                        
                        <DataGrid Grid.Row="1" x:Name="CallsDataGrid" 
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionChanged="CallsDataGrid_SelectionChanged"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False"
                                  Margin="5">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="时间" Binding="{Binding Timestamp}" Width="150"/>
                                <DataGridTextColumn Header="API名称" Binding="{Binding ApiName}" Width="150"/>
                                <DataGridTextColumn Header="模块" Binding="{Binding ModuleName}" Width="100"/>
                                <DataGridTextColumn Header="参数" Binding="{Binding Parameters}" Width="*"/>
                                <DataGridTextColumn Header="原始返回值" Binding="{Binding OriginalReturnValue}" Width="100"/>
                                <DataGridTextColumn Header="修改后返回值" Binding="{Binding ModifiedReturnValue}" Width="100"/>
                                <DataGridTextColumn Header="状态" Binding="{Binding IsModified, Converter={StaticResource BoolToModifiedConverter}}" Width="60"/>
                                <DataGridTextColumn Header="重定向" Binding="{Binding IsRedirected, Converter={StaticResource BoolToYesNoConverter}}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
                
                <!-- 分隔线 -->
                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="Gray"/>
                
                <!-- 详细信息和返回值修改 -->
                <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Height="200">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="#E0E0E0" CornerRadius="5,5,0,0">
                            <TextBlock Text="调用详细信息" FontWeight="Bold" Margin="10" VerticalAlignment="Center"/>
                        </Border>
                        
                        <Grid Grid.Row="1" Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="300"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- 左侧：详细信息 -->
                            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="时间戳: " FontWeight="Bold"/>
                                    <TextBox x:Name="DetailTimestampTextBox" IsReadOnly="True" Margin="0,0,0,5"/>
                                    
                                    <TextBlock Text="API名称: " FontWeight="Bold"/>
                                    <TextBox x:Name="DetailApiNameTextBox" IsReadOnly="True" Margin="0,0,0,5"/>
                                    
                                    <TextBlock Text="模块名称: " FontWeight="Bold"/>
                                    <TextBox x:Name="DetailModuleNameTextBox" IsReadOnly="True" Margin="0,0,0,5"/>
                                    
                                    <TextBlock Text="进程ID: " FontWeight="Bold"/>
                                    <TextBox x:Name="DetailProcessIdTextBox" IsReadOnly="True" Margin="0,0,0,5"/>
                                    
                                    <TextBlock Text="进程名称: " FontWeight="Bold"/>
                                    <TextBox x:Name="DetailProcessNameTextBox" IsReadOnly="True" Margin="0,0,0,5"/>
                                    
                                    <TextBlock Text="参数: " FontWeight="Bold"/>
                                    <TextBox x:Name="DetailParametersTextBox" IsReadOnly="True" Height="60" TextWrapping="Wrap" 
                                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,5"/>
                                </StackPanel>
                            </ScrollViewer>
                            
                            <!-- 右侧：返回值修改 -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="原始返回值: " FontWeight="Bold"/>
                                <TextBox x:Name="DetailOriginalReturnValueTextBox" IsReadOnly="True" Margin="0,0,0,10"/>
                                
                                <TextBlock Text="修改后返回值: " FontWeight="Bold"/>
                                <TextBox x:Name="DetailModifiedReturnValueTextBox" Margin="0,0,0,10"/>
                                
                                <Button Content="应用修改" Click="ApplyModifyReturnValue_Click" 
                                        Background="#FF9800" Foreground="White" Margin="0,0,0,10"/>
                                
                                <TextBlock Text="重定向目标: " FontWeight="Bold"/>
                                <TextBox x:Name="DetailRedirectTargetTextBox" IsReadOnly="True" Margin="0,0,0,5"/>
                                
                                <TextBlock Text="调用栈: " FontWeight="Bold"/>
                                <TextBox x:Name="DetailCallStackTextBox" IsReadOnly="True" Height="50" TextWrapping="Wrap" 
                                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        
        <!-- 底部状态栏 -->
        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Margin="0,10,0,0">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" x:Name="StatusTextBlock" Text="状态: 未连接" VerticalAlignment="Center"/>
                
                <TextBlock Grid.Column="2" x:Name="HookStatusTextBlock" Text="钩取状态: 未开始" VerticalAlignment="Center" Margin="20,0"/>
                
                <TextBlock Grid.Column="3" x:Name="CallCountTextBlock" Text="捕获调用数: 0" VerticalAlignment="Center" Margin="20,0"/>
                
                <TextBlock Grid.Column="4" x:Name="LogPathTextBlock" Text="日志路径: " VerticalAlignment="Center" Margin="20,0"/>
            </Grid>
        </Border>
    </Grid>
    
    <Window.Resources>
        <local:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
        <local:BoolToModifiedConverter x:Key="BoolToModifiedConverter"/>
        <local:BoolToYesNoConverter x:Key="BoolToYesNoConverter"/>
    </Window.Resources>
</Window>
