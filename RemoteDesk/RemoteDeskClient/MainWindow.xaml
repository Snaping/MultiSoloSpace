<Window x:Class="RemoteDeskClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteDesk - WebRTC Remote Desktop"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        Closing="Window_Closing">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                   Text="RemoteDesk - WebRTC Remote Desktop"
                   FontSize="22" FontWeight="Bold" 
                   Margin="0,0,0,15" Foreground="#2C3E50"/>
        
        <Border Grid.Row="1" Grid.Column="0" 
                Background="White" CornerRadius="8" Padding="15"
                BorderBrush="#DDD" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Connection Settings" FontSize="14" FontWeight="Bold" 
                               Margin="0,0,0,10" Foreground="#34495E"/>
                    
                    <TextBlock Text="Signaling Server:" Margin="0,0,0,3" Foreground="#555"/>
                    <TextBox x:Name="txtSignalingServer" 
                             Text="ws://localhost:5000/ws"
                             Margin="0,0,0,10" Padding="8"
                             BorderBrush="#DDD" BorderThickness="1"/>
                    
                    <TextBlock Text="Room ID:" Margin="0,0,0,3" Foreground="#555"/>
                    <TextBox x:Name="txtRoomId" 
                             Text="Room123"
                             Margin="0,0,0,10" Padding="8"
                             BorderBrush="#DDD" BorderThickness="1"/>
                    
                    <TextBlock Text="Mode:" Margin="0,0,0,5" Foreground="#555"/>
                    <RadioButton x:Name="rbController" Content="Controller (View and Control Remote)"
                                 IsChecked="True"
                                 Margin="0,0,0,5"
                                 GroupName="Mode"/>
                    <RadioButton x:Name="rbControlled" Content="Controlled (Share Screen)"
                                 Margin="0,0,0,10"
                                 GroupName="Mode"/>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button x:Name="btnConnect" Content="Connect" 
                                Click="BtnConnect_Click"
                                Background="#3498DB" Foreground="White"
                                Padding="10,8" Margin="0,0,5,0"
                                Cursor="Hand" BorderThickness="0"/>
                        
                        <Button x:Name="btnDisconnect" Content="Disconnect" 
                                Click="BtnDisconnect_Click"
                                Background="#E74C3C" Foreground="White"
                                Padding="10,8" Margin="5,0,0,0"
                                Cursor="Hand" BorderThickness="0" Grid.Column="1"
                                IsEnabled="False"/>
                    </Grid>
                    
                    <Border Background="#E8F4FD" CornerRadius="5" Padding="10" Margin="0,15,0,10">
                        <StackPanel>
                            <TextBlock Text="Connection Status:" FontWeight="Bold" Foreground="#2C3E50"/>
                            <TextBlock x:Name="txtStatus" Text="Disconnected" 
                                       Foreground="#E74C3C" FontWeight="Bold"
                                       Margin="0,5,0,0"/>
                            <TextBlock x:Name="txtModeDisplay" Text="Mode: None" 
                                       Foreground="#555"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Text="Quick Actions" FontSize="14" FontWeight="Bold" 
                               Margin="0,15,0,10" Foreground="#34495E"/>
                    
                    <GroupBox Header="Screen Capture Settings" Padding="10" Margin="0,5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Text="FPS:" Margin="0,5,10,5" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmbFps" SelectedIndex="2" Margin="0,5,0,5"
                                      Grid.Column="1">
                                <ComboBoxItem Content="5 FPS"/>
                                <ComboBoxItem Content="10 FPS"/>
                                <ComboBoxItem Content="15 FPS"/>
                                <ComboBoxItem Content="30 FPS"/>
                            </ComboBox>
                            
                            <TextBlock Text="Quality:" Margin="0,5,10,5" Grid.Row="1" VerticalAlignment="Center"/>
                            <Slider x:Name="sldQuality" Minimum="10" Maximum="100" Value="80"
                                    Margin="0,5,0,5" Grid.Row="1" Grid.Column="1"
                                    AutoToolTipPlacement="TopLeft"/>
                        </Grid>
                    </GroupBox>
                    
                    <GroupBox Header="Mouse and Keyboard (Controller Mode" Padding="10" Margin="0,5,0,10">
                        <StackPanel>
                            <CheckBox x:Name="chkSendCtrlAltDel" Content="Enable Ctrl+Alt+Del"
                                      Margin="0,0,0,5"/>
                            <TextBlock Text="Note: Click on the remote screen to start controlling."
                                       Foreground="#7F8C8D" TextWrapping="Wrap"
                                       FontSize="11"/>
                        </StackPanel>
                    </GroupBox>
                    
                    <GroupBox Header="Clipboard" Padding="10" Margin="0,5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <Button x:Name="btnSendClipboard" Content="Send Clipboard"
                                    Click="BtnSendClipboard_Click"
                                    Background="#9B59B6" Foreground="White"
                                    Padding="10,5" Margin="0,0,0,5"
                                    Cursor="Hand" BorderThickness="0"/>
                            
                            <Button x:Name="btnReceiveClipboard" Content="Receive Clipboard"
                                    Click="BtnReceiveClipboard_Click"
                                    Background="#8E44AD" Foreground="White"
                                    Padding="10,5" Margin="0,5,0,0"
                                    Cursor="Hand" BorderThickness="0" Grid.Row="1"/>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Border>
        
        <Border Grid.Row="1" Grid.Column="1" 
                Background="White" CornerRadius="8" Padding="15" Margin="10,0,0,0"
                BorderBrush="#DDD" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock x:Name="txtRemoteScreen" Text="Remote Screen" FontWeight="Bold" 
                           Margin="0,0,0,10" Foreground="#34495E"/>
                
                <Border Grid.Row="1" Background="#2C3E50" CornerRadius="5"
                        MouseDown="RemoteScreen_MouseDown"
                        MouseMove="RemoteScreen_MouseMove"
                        MouseUp="RemoteScreen_MouseUp"
                        MouseWheel="RemoteScreen_MouseWheel"
                        KeyDown="RemoteScreen_KeyDown"
                        KeyUp="RemoteScreen_KeyUp"
                        Focusable="True">
                    <Viewbox Stretch="Uniform">
                        <Image x:Name="imgRemoteScreen" Margin="5"
                               Stretch="None"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Viewbox>
                </Border>
            </Grid>
        </Border>
        
        <Border Grid.Row="2" Grid.ColumnSpan="2" 
                Background="#2C3E50" CornerRadius="8" Padding="10"
                Margin="0,10,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Text="Log Output" FontWeight="Bold" 
                           Margin="0,0,0,5" Foreground="#ECF0F1"/>
                
                <TextBox x:Name="txtLog" Grid.Row="1"
                         Background="#34495E" Foreground="#ECF0F1"
                         BorderThickness="0" IsReadOnly="True"
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="80" FontFamily="Consolas" FontSize="11"/>
            </Grid>
        </Border>
    </Grid>
</Window>
