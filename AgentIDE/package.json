{
  "name": "agent-ide",
  "version": "1.0.0",
  "description": "AgentIDE - A desktop tool for AI agent development",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "keywords": ["electron", "agent", "ide", "ai"],
  "author": "AgentIDE",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.agentide.app",
    "productName": "AgentIDE",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icons/icon.ico"
    }
  }
}